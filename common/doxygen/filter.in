#!/bin/bash
filename=`expr "X$1" : "^X.*/\([^/]*\)"`
case "${filename}" in
    SWIG*.i)
        # Filter SWIG interface files
        @SED@ -n -f @abs_srcdir@/filter_swig.sed "$1" | tee "$1.filtered"
        ;;
    *.py)
        # Filter Python source files
        doxypypy -a -c "$1" | tee "$1.filtered"
        ;;
    *)
        # Output all other files unfiltered
        cat "$1"
        ;;
esac
